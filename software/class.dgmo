class Ship Class Hierarchy

Vessel interface
  + sail(): void
  + anchor(): void

Ship implements Vessel abstract
  # name: string
  # crew: number
  + getName(): string

Galleon extends Ship
  - cannons: number
  + fire(): void

Sloop extends Ship
  - speed: number
  + flee(): void

ShipType enum
  Galleon
  Sloop
  Frigate

Ship -> ShipType : has type
